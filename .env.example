# Optional Docker compose overrides (defaults keep live data outside tracked files)
# SMARTHOME_DATA_DIR=./runtime-data
# SMARTHOME_UPLOADS_DIR=./runtime-uploads
# SMARTHOME_SEED_DATA_DIR=./data

# Kelder production (docker-compose.prod.yml) only needs runtime volumes on disk.
# After pushing to main, either:
#   - let the self-hosted GitHub Actions runner deploy automatically, or
#   - run: ./scripts/kelder-deploy.sh
